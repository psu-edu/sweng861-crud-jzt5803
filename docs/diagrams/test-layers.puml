@startuml test-layers
!theme plain
skinparam defaultFontName Calibri
skinparam defaultFontSize 13
skinparam backgroundColor white
skinparam packageBorderColor #1e3a5f
skinparam packageBorderThickness 2
skinparam componentStyle rectangle
skinparam componentBackgroundColor #f0f4f8
skinparam componentBorderColor #1e3a5f
skinparam ArrowColor #2196f3
skinparam ArrowThickness 2

package "Layer 1 — Unit Tests  (196 cases)" #dce7f5 {
  component "auth · validation · rateLimit · events\napiErrors · weatherService · middleware\nFast · isolated · no external dependencies" as unit
}

package "Layer 2 — Frontend Tests  (124 cases)" #e8f5e9 {
  component "LoginPage · MetricForm · Navbar\nWeatherWidget · AuthProvider · apiClient · Spinner\nReact Testing Library · jsdom" as frontend
}

package "Layer 3 — Integration  (api.test.js)" #fff8e1 {
  component "register → login → CRUD → weather → domain events\nNode --test runner · live server on :3001\n(run locally — not in CI)" as integration
}

package "CI Quality Gate" #ffcdd2 {
  component "**GitHub Actions — runs on every push to main**\nPipeline FAILS if any single test fails\nCoverage artifact retained 14 days" as ci
}

unit -down-> ci : runs in CI
frontend -down-> ci : runs in CI
integration -[dashed]-> ci : local only

@enduml
